# ── Thirdwave IMS — Docker Production Environment ──────────────────────────
# Use with: docker-compose up --build -d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8004
ENVIRONMENT=production

# ── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong secret key before deploying
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=thirdwave-ims-hono-prod-secret-change-me

# ── Email / OTP ───────────────────────────────────────────────────────────────
# Configure your SMTP server for production email
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Thirdwave IMS <noreply@thirdwave.co.jp>
OTP_EXPIRE_MINUTES=10

# ── Admin notification ────────────────────────────────────────────────────────
ADMIN_EMAIL=

# ── AI extraction (Thirdwave AI Gateway) ──────────────────────────────────────
AI_MODEL_URL=https://tw-gateway.twave.co.jp
AI_MODEL_NAME=Qwen/Qwen-AgentWorld-35B-A3B
AI_API_KEY=vllm-3OkQGYd-pEgzKWSl3ItYzZssumyNt0WM8g-3BjNaOR8

# ── CORS (for production domain) ──────────────────────────────────────────────
# Update with your actual production domain
ALLOWED_ORIGINS=http://localhost,https://your-domain.com,https://api.your-domain.com

# ── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Login lockout ─────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_WINDOW_MINUTES=10
LOCKOUT_MINUTES=15

# ── Misc ──────────────────────────────────────────────────────────────────────
REVEAL_EMAIL_NOT_FOUND=false
