# ── Server ────────────────────────────────────────────────────────────────────
PORT=8001
ENVIRONMENT=local

# ── Database (PostgreSQL via Docker) ─────────────────────────────────────────
DATABASE_URL="postgresql://ims_user:ims_password@localhost:5432/ims_db"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=change-this-in-production-use-crypto-random-bytes-32
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ── Email / OTP ───────────────────────────────────────────────────────────────
# Leave SMTP_USER / SMTP_PASSWORD blank → dev mode (OTP printed to console)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Thirdwave IMS <noreply@thirdwave.co.jp>
OTP_EXPIRE_MINUTES=10

# ── Login lockout ─────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_WINDOW_MINUTES=10
LOCKOUT_MINUTES=15

# ── Admin notification ────────────────────────────────────────────────────────
ADMIN_EMAIL=

# ── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Misc ─────────────────────────────────────────────────────────────────────
REVEAL_EMAIL_NOT_FOUND=true
