@app.post("/extract-report")
async def extract_report(
    file: UploadFile = File(...),
    previous_state_json: Optional[str] = Form(default=None),
    include_raw_text: bool = Form(default=False),
):
    """
    Upload one PDF report and get:
    - extracted JSON
    - company standard Excel fields
    - formula calculated fields
 
    Optional previous_state_json example:
    {
    "cumulative_capital_contributions": 2519664,
    "remaining_commitment": 2869940,
    "cumulative_cash_flow": -2519664
    }
    """
    file_extension = os.path.splitext(file.filename or "")[1].lower()
 
    if file_extension != ".pdf":
        return {
            "extraction_status": "error",
            "message": "Currently only PDF files are supported.",
        }
 
    unique_filename = f"{uuid.uuid4()}_{file.filename}"
    file_path = os.path.join(UPLOAD_DIR, unique_filename)
 
    with open(file_path, "wb") as buffer:
        buffer.write(await file.read())
 
    text = extract_pdf_text(file_path)
 
    if not text.strip():
        return {
            "extraction_status": "error",
            "message": "No text found in PDF. This may be a scanned PDF and needs OCR.",
        }
 
    previous_state = parse_previous_state(previous_state_json)
    normalized_text = normalize_text(text)
 
    # Router 1: NB Real Estate Secondary Opportunities module
    # This keeps NB-specific extraction/calculation separate from the Hamilton default logic.
    if is_nb_realestate_report(normalized_text):
        if not NB_REALESTATE_MODULE_AVAILABLE:
            return {
                "extraction_status": "error",
                "message": "NB Real Estate module is not available. Make sure nb_realestate_module_updated.py is in the same folder as this main file.",
                "import_error": NB_REALESTATE_IMPORT_ERROR,
            }
 
        result = extract_nb_realestate_report(
            text=normalized_text,
            file_name=file.filename or unique_filename,
            previous_state=previous_state,
        )
 
        if include_raw_text:
            result["raw_text"] = normalized_text
 
        return result
 
    # Default router: existing Hamilton Secondary capital call logic
    result = extract_report_data(normalized_text, file.filename or unique_filename)
 
    calculation_result = calculate_excel_formula_fields(
        extracted_json=result,
        previous_state=previous_state,
    )
 
    result["calculation_result"] = calculation_result
    result["final_excel_fields"] = calculation_result["final_excel_fields_for_frontend"]
 
    if include_raw_text:
        result["raw_text"] = normalized_text
 
    return result
 
 
