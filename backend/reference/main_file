def build_breakdown(all_fields: Dict[str, Any]) -> Dict[str, Any]:
    capital_call_breakdown = []
 
    if all_fields.get("capital_call_for_investments") is not None:
        capital_call_breakdown.append({
            "purpose": "investment",
            "label": "Capital call for investments",
            "amount": all_fields["capital_call_for_investments"],
        })
 
    if all_fields.get("capital_call_for_management_fees") is not None:
        capital_call_breakdown.append({
            "purpose": "management_fee",
            "label": "Capital call for management fees",
            "amount": all_fields["capital_call_for_management_fees"],
        })
 
    if all_fields.get("capital_call_for_expenses") is not None:
        capital_call_breakdown.append({
            "purpose": "fund_expense",
            "label": "Capital call for expenses",
            "amount": all_fields["capital_call_for_expenses"],
        })
 
    return {
        "capital_call_breakdown": capital_call_breakdown,
        "distribution_breakdown": [],
    }
 
 
# =========================================================
# 5. Map extracted values to company standard Excel fields
# =========================================================
 
def map_to_excel_fields(
    document_type: str,
    all_fields: Dict[str, Any],
    breakdown: Dict[str, Any],
) -> Dict[str, Any]:
    commitment_amount = all_fields.get("capital_commitment")
    transaction_date = all_fields.get("capital_call_due_date")
 
    capital_contribution_amount = None
    distribution_amount_received = None
    reinvestable_amount = None
 
    if document_type == "capital_call_notice":
        capital_contribution_amount = (
            all_fields.get("capital_call_amount")
            or all_fields.get("transaction_total")
        )
 
        # IMPORTANT:
        # In Hamilton capital call notice, "Recallable amounts distributed" is a cumulative report value.
        # It is NOT the current row reinvestable amount for formula F = previous F - B + D.
        # So current row reinvestable amount should be 0 for capital call.
        reinvestable_amount = 0.0
 
    elif document_type == "distribution_notice":
        # Later you can add distribution template rules here.
        distribution_amount_received = all_fields.get("distribution_amount_received")
        reinvestable_amount = all_fields.get("reinvestable_amount") or 0.0
 
    cumulative_capital_contributions = all_fields.get("amounts_drawn")
    remaining_commitment = all_fields.get("remaining_unfunded_commitment")
 
    cash_flow = None
    if capital_contribution_amount is not None:
        cash_flow = -capital_contribution_amount
    if distribution_amount_received is not None:
        cash_flow = distribution_amount_received - amount_or_zero(capital_contribution_amount)
 
    if document_type == "capital_call_notice":
        remarks = "Capital call notice. Payment required for investments, management fees, and fund expenses."
    elif document_type == "distribution_notice":
        remarks = "Distribution notice. Distribution amount received from fund."
    else:
        remarks = "Auto extracted from uploaded investment report."
 
    return {
        # 出資契約効力発生日
        "subscription_agreement_effective_date": None,
 
        # 出資約束金額
        "commitment_amount": commitment_amount,
 
        # 実行日
        "transaction_date": transaction_date,
 
        # 出資払込金額
        "capital_contribution_amount": capital_contribution_amount,
 
        # 出資受領金額
        "distribution_amount_received": distribution_amount_received,
 
        # （うち再投資充当可能額） - current row value for formula
        "reinvestable_amount": reinvestable_amount,
 
        # E＝直近E+B 出資額累計 - report cumulative value if available
        "cumulative_capital_contributions": cumulative_capital_contributions,
 
        # F＝直近F-B+D 投資余力 - report value if available
        "remaining_commitment_formula_value": remaining_commitment,
 
        # 投資余力
        "remaining_commitment": remaining_commitment,
 
        # キャッシュフロー
        "cash_flow": cash_flow,
 
        # 備考
        "remarks": remarks,
 
        # 分配明細
        "distribution_details": breakdown.get("distribution_breakdown", []),
    }
 
 
# =========================================================
# 6. Formula calculation from extracted JSON + previous state
# =========================================================
 
def calculate_excel_formula_fields(
    extracted_json: Dict[str, Any],
    previous_state: Optional[Dict[str, Any]] = None,
) -> Dict[str, Any]:
    """
    Calculates formula-based Excel columns.
 
    Current row formula logic:
    E cumulative capital contributions = previous E + current capital contribution amount
    F remaining commitment = previous F - current capital contribution amount + current reinvestable amount
    Current cash flow = distribution amount received - capital contribution amount
    Cumulative cash flow = previous cumulative cash flow + current cash flow
    Distribution not allocated to reinvestment = distribution amount received - reinvestable amount
    """
    excel = extracted_json.get("excel_fields", {})
    all_fields = extracted_json.get("all_extracted_fields", {})
    breakdown = extracted_json.get("breakdown", {})
    document_type = extracted_json.get("document_type")
 
    capital_contribution = amount_or_zero(excel.get("capital_contribution_amount"))
    distribution_received = amount_or_zero(excel.get("distribution_amount_received"))
 
    # For capital call, reinvestable amount is current row value = 0.
    # Do not use cumulative recallable_amounts_distributed as current D.
    reinvestable_amount = amount_or_zero(excel.get("reinvestable_amount"))
 
    current_transaction_cash_flow = distribution_received - capital_contribution
    distribution_not_allocated = distribution_received - reinvestable_amount
 
    calculation_sources = {}
    warnings: List[str] = []
 
    if document_type == "capital_call_notice" and all_fields.get("recallable_amounts_distributed") is not None:
        warnings.append(
            "recallable_amounts_distributed was extracted as a cumulative report value; it was not used as the current row reinvestable amount."
        )
 
    if previous_state:
        prev_cumulative = amount_or_zero(previous_state.get("cumulative_capital_contributions"))
        prev_remaining = amount_or_zero(previous_state.get("remaining_commitment"))
        prev_cumulative_cash_flow = amount_or_zero(previous_state.get("cumulative_cash_flow"))
 
        calculated_cumulative = prev_cumulative + capital_contribution
        calculated_remaining = prev_remaining - capital_contribution + reinvestable_amount
        calculated_cumulative_cash_flow = prev_cumulative_cash_flow + current_transaction_cash_flow
 
        calculation_sources["cumulative_capital_contributions"] = "calculated_from_previous_state"
        calculation_sources["remaining_commitment"] = "calculated_from_previous_state"
        calculation_sources["cumulative_cash_flow"] = "calculated_from_previous_state"
    else:
        # If previous row is not available, use report cumulative values as fallback.
        calculated_cumulative = all_fields.get("amounts_drawn")
        calculated_remaining = all_fields.get("remaining_unfunded_commitment")
        calculated_cumulative_cash_flow = None
 
        calculation_sources["cumulative_capital_contributions"] = "from_report_cumulative_value_no_previous_state"
        calculation_sources["remaining_commitment"] = "from_report_cumulative_value_no_previous_state"
        calculation_sources["cumulative_cash_flow"] = "not_calculated_previous_state_missing"
        warnings.append("previous_state was not provided, so cumulative formula values used report cumulative values where available.")
 
    # Capital call breakdown validation
    capital_call_breakdown = breakdown.get("capital_call_breakdown", [])
    capital_call_breakdown_total = sum(
        amount_or_zero(item.get("amount")) for item in capital_call_breakdown
    )
    reported_capital_call_amount = amount_or_zero(all_fields.get("capital_call_amount"))
    reported_transaction_total = amount_or_zero(all_fields.get("transaction_total"))
 
    is_capital_call_total_matched = None
    if capital_call_breakdown and reported_capital_call_amount:
        is_capital_call_total_matched = abs(capital_call_breakdown_total - reported_capital_call_amount) < 0.01
 
    # Compare calculated values with report cumulative values if available
    report_cumulative = all_fields.get("amounts_drawn")
    report_remaining = all_fields.get("remaining_unfunded_commitment")
 
    cumulative_matches_report = None
    remaining_matches_report = None
 
    if calculated_cumulative is not None and report_cumulative is not None:
        cumulative_matches_report = abs(calculated_cumulative - report_cumulative) < 0.01
 
    if calculated_remaining is not None and report_remaining is not None:
        remaining_matches_report = abs(calculated_remaining - report_remaining) < 0.01
 
    final_excel_fields = {
        **excel,
        "cumulative_capital_contributions": calculated_cumulative,
        "remaining_commitment_formula_value": calculated_remaining,
        "remaining_commitment": calculated_remaining,
        "cash_flow": current_transaction_cash_flow,
        "distribution_not_allocated_to_reinvestment": distribution_not_allocated,
    }
 
    return {
        "input_values_for_current_row": {
            "subscription_agreement_effective_date": excel.get("subscription_agreement_effective_date"),
            "commitment_amount": excel.get("commitment_amount"),
            "transaction_date": excel.get("transaction_date"),
            "capital_contribution_amount": capital_contribution,
            "distribution_amount_received": distribution_received,
            "reinvestable_amount": reinvestable_amount,
        },
        "previous_state_used": previous_state,
        "calculated_excel_fields": {
            "cumulative_capital_contributions": calculated_cumulative,
            "remaining_commitment_formula_value": calculated_remaining,
            "remaining_commitment": calculated_remaining,
            "current_transaction_cash_flow": current_transaction_cash_flow,
            "cumulative_cash_flow": calculated_cumulative_cash_flow,
            "distribution_not_allocated_to_reinvestment": distribution_not_allocated,
            "remarks": excel.get("remarks"),
            "distribution_details": excel.get("distribution_details", []),
        },
        "final_excel_fields_for_frontend": final_excel_fields,
        "calculation_sources": calculation_sources,
        "report_cumulative_values": {
            "amounts_drawn": all_fields.get("amounts_drawn"),
            "recallable_amounts_distributed": all_fields.get("recallable_amounts_distributed"),
            "remaining_unfunded_commitment": all_fields.get("remaining_unfunded_commitment"),
            "cumulative_distributions": all_fields.get("cumulative_distributions"),
        },
        "validation": {
            "capital_call_breakdown_total": capital_call_breakdown_total if capital_call_breakdown else None,
            "reported_capital_call_amount": all_fields.get("capital_call_amount"),
            "reported_transaction_total": all_fields.get("transaction_total"),
            "is_capital_call_total_matched": is_capital_call_total_matched,
            "report_cumulative_capital_contributions": report_cumulative,
            "calculated_cumulative_capital_contributions": calculated_cumulative,
            "is_cumulative_capital_contributions_matched_with_report": cumulative_matches_report,
            "report_remaining_commitment": report_remaining,
            "calculated_remaining_commitment": calculated_remaining,
            "is_remaining_commitment_matched_with_report": remaining_matches_report,
            "needs_review": True,
        },
        "warnings": warnings,
    }
 
 
# =========================================================
# 7. Validation for extracted Excel fields
# =========================================================
 
def build_extraction_validation(
    excel_fields: Dict[str, Any],
    all_fields: Dict[str, Any],
    breakdown: Dict[str, Any],
) -> Dict[str, Any]:
    required_excel_fields = [
        "subscription_agreement_effective_date",
        "commitment_amount",
        "transaction_date",
        "capital_contribution_amount",
        "distribution_amount_received",
        "reinvestable_amount",
        "cumulative_capital_contributions",
        "remaining_commitment",
        "cash_flow",
        "remarks",
        "distribution_details",
    ]
 
    missing_excel_fields = []
    matched_excel_fields = []
 
    for field in required_excel_fields:
        value = excel_fields.get(field)
        if value is None or value == [] or value == "":
            missing_excel_fields.append(field)
        else:
            matched_excel_fields.append(field)
 
    capital_call_breakdown = breakdown.get("capital_call_breakdown", [])
    capital_call_breakdown_total = None
    is_capital_call_total_matched = None
 
    if capital_call_breakdown:
        capital_call_breakdown_total = sum(
            amount_or_zero(item.get("amount")) for item in capital_call_breakdown
        )
        reported_total = all_fields.get("capital_call_amount") or all_fields.get("transaction_total")
        if reported_total is not None:
            is_capital_call_total_matched = abs(capital_call_breakdown_total - reported_total) < 0.01
 
    return {
        "missing_excel_fields": missing_excel_fields,
        "matched_excel_fields": matched_excel_fields,
        "calculation_checks": {
            "capital_call_breakdown_total": capital_call_breakdown_total,
            "reported_capital_call_amount": all_fields.get("capital_call_amount"),
            "reported_transaction_total": all_fields.get("transaction_total"),
            "is_capital_call_total_matched": is_capital_call_total_matched,
        },
        "needs_review": True,
    }
 
 
# =========================================================
# 8. Main extraction function
# =========================================================
 
def extract_report_data(text: str, file_name: str) -> Dict[str, Any]:
    text = normalize_text(text)
 
    company_fund_info = extract_company_and_fund(text)
    document_type = detect_document_type(text)
    currency = detect_currency(text)
 
    all_extracted_fields = extract_all_fields(text)
    breakdown = build_breakdown(all_extracted_fields)
 
    excel_fields = map_to_excel_fields(
        document_type=document_type,
        all_fields=all_extracted_fields,
        breakdown=breakdown,
    )
 
    extraction_validation = build_extraction_validation(
        excel_fields=excel_fields,
        all_fields=all_extracted_fields,
        breakdown=breakdown,
    )
 
    return {
        "source_file_name": file_name,
        "extraction_status": "success",
        "document_type": document_type,
        "company_name": company_fund_info.get("company_name"),
        "fund_name": company_fund_info.get("fund_name"),
        "currency": currency,
        "excel_fields": excel_fields,
        "all_extracted_fields": all_extracted_fields,
        "breakdown": breakdown,
        "validation": extraction_validation,
    }
 
 
