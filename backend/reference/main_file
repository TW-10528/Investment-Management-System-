# =========================================================
    # 1. Basic utility functions
    # =========================================================
 
def extract_pdf_text(file_path: str) -> str:
    """Extract text from a normal text-based PDF."""
    text_parts: List[str] = []
 
    with pdfplumber.open(file_path) as pdf:
        for page in pdf.pages:
            page_text = page.extract_text() or ""
            text_parts.append(page_text)
 
    return "\n".join(text_parts)
 
 
def normalize_text(text: str) -> str:
    text = text.replace("\xa0", " ")
    text = re.sub(r"[ \t]+", " ", text)
    text = re.sub(r"\n\s+", "\n", text)
    return text.strip()
 
 
def clean_amount(value: Optional[str], absolute: bool = False) -> Optional[float]:
    """
    Converts report amount text to float.
 
    Examples:
    $253,093      -> 253093.0
    253,093       -> 253093.0
    (2,772,757)   -> -2772757.0
 
    If absolute=True, returns positive value.
    """
    if not value:
        return None
 
    value = value.strip()
    is_negative = False
 
    if value.startswith("(") and value.endswith(")"):
        is_negative = True
        value = value[1:-1]
 
    value = (
        value.replace("$", "")
        .replace("¥", "")
        .replace(",", "")
        .replace(" ", "")
    )
 
    try:
        amount = float(value)
        if is_negative:
            amount = -amount
        if absolute:
            amount = abs(amount)
        return amount
    except ValueError:
        return None
 
 
def amount_or_zero(value: Optional[float]) -> float:
    return float(value) if value is not None else 0.0
 
 
def normalize_date(date_text: Optional[str]) -> Optional[str]:
    """Converts common date formats to YYYY-MM-DD."""
    if not date_text:
        return None
 
    date_text = date_text.strip()
 
    possible_formats = [
        "%B %d, %Y",   # March 24, 2026
        "%b %d, %Y",   # Mar 24, 2026
        "%m/%d/%Y",
        "%Y-%m-%d",
    ]
 
    for fmt in possible_formats:
        try:
            parsed = datetime.strptime(date_text, fmt)
            return parsed.strftime("%Y-%m-%d")
        except ValueError:
            pass
 
    return date_text
 
 
def find_amount_by_label(
    text: str,
    labels: List[str],
    absolute: bool = False,
) -> Optional[float]:
    """
    Finds an amount after a label.
 
    Handles:
    Capital Call Amount: $253,093
    Capital commitment $ 5,000,000
    Amounts drawn (2,772,757)
    """
    for label in labels:
        pattern = rf"{re.escape(label)}\s*:?\s*\$?\s*([\(\)\d,]+)"
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            return clean_amount(match.group(1), absolute=absolute)
 
    return None
 
 
def find_date_by_label(text: str, labels: List[str]) -> Optional[str]:
    for label in labels:
        pattern = rf"{re.escape(label)}\s*:?\s*([A-Za-z]+\s+\d{{1,2}},\s+\d{{4}})"
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            return normalize_date(match.group(1))
 
    return None
 
 
def find_notice_date(text: str) -> Optional[str]:
    pattern = r"\b([A-Za-z]+\s+\d{1,2},\s+\d{4})\b"
    match = re.search(pattern, text)
    if match:
        return normalize_date(match.group(1))
    return None
 
 
def parse_previous_state(previous_state_json: Optional[str]) -> Optional[Dict[str, Any]]:
    """
    previous_state_json can be passed from frontend/database as JSON text.
 
    Example:
    {
    "cumulative_capital_contributions": 2519664,
    "remaining_commitment": 2869940,
    "cumulative_cash_flow": -2519664
    }
    """
    if not previous_state_json:
        return None
 
    try:
        parsed = json.loads(previous_state_json)
        if isinstance(parsed, dict):
            return parsed
    except json.JSONDecodeError:
        return None
 
    return None
 
 
# =========================================================
# 2. Detection functions
# =========================================================
 
def detect_document_type(text: str) -> str:
    lower_text = text.lower()
 
    if "capital call" in lower_text:
        return "capital_call_notice"
 
    if "distribution" in lower_text and "capital call" not in lower_text:
        return "distribution_notice"
 
    if "capital account statement" in lower_text:
        return "capital_account_statement"
 
    return "unknown"
 
 
def detect_currency(text: str) -> str:
    """
    Only detects report currency. Does NOT convert currency.
    """
    if "$" in text or " usd" in text.lower():
        return "USD"
 
    if "¥" in text or "jpy" in text.lower():
        return "JPY"
 
    if "eur" in text.lower() or "€" in text:
        return "EUR"
 
    return "unknown"
 
 
def extract_company_and_fund(text: str) -> Dict[str, Optional[str]]:
    fund_name = None
    company_name = None
 
    # Hamilton sample-specific fund name extraction
    fund_match = re.search(
        r"(Hamilton Lane Secondary Fund VI-B LP)",
        text,
        re.IGNORECASE,
    )
    if fund_match:
        fund_name = fund_match.group(1).strip()
 
    # Generic investor extraction
    investor_match = re.search(r"Investor:\s*(.+)", text, re.IGNORECASE)
    if investor_match:
        company_name = investor_match.group(1).strip()
 
    # Fallback: find line containing Fund if specific fund regex failed
    if fund_name is None:
        for line in text.splitlines():
            if "fund" in line.lower() and len(line.strip()) < 120:
                fund_name = line.strip()
                break
 
    return {
        "company_name": company_name,
        "fund_name": fund_name,
    }
 
 
