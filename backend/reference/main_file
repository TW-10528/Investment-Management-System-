def is_nb_realestate_report(text: str) -> bool:
    """Detect NB Real Estate Secondary Opportunities reports."""
    lower_text = text.lower()
    return (
        "nb real estate secondary opportunities" in lower_text
        or "nb alternatives advisers" in lower_text
        or "amount due from limited partner" in lower_text
    )
 
 
