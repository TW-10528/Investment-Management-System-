// Thirdwave IMS — Prisma Schema
// Aviary pattern: Hono + TypeScript + Prisma + PostgreSQL
// Mirrors the original SQLAlchemy models exactly

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  user
  board_member
  finance_staff
  finance_manager
  admin
}

enum UserStatus {
  pending
  active
  inactive
}

enum CallStatus {
  pending
  approved
  paid
  cancelled
}

// ── Models ────────────────────────────────────────────────────────────────────

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  fullName       String?    @map("full_name")
  fullNameJp     String?    @map("full_name_jp")
  hashedPassword String     @map("hashed_password")
  role           UserRole   @default(user)
  status         UserStatus @default(pending)
  isActive       Boolean    @default(true) @map("is_active")
  lastLogin      DateTime?  @map("last_login")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  @@map("users")
}

model Fund {
  id                    String    @id @default(uuid())
  fundName              String    @map("fund_name")
  fundNameJp            String?   @map("fund_name_jp")
  manager               String?
  administrator         String?
  strategy              String?
  vintageYear           Int?      @map("vintage_year")
  currency              String    @default("USD")
  commitmentUsd         Decimal   @default(0) @db.Decimal(20, 6) @map("commitment_usd")
  commitmentJpy         BigInt?   @map("commitment_jpy")
  entryFxRate           Decimal?  @db.Decimal(12, 6) @map("entry_fx_rate")
  contractDate          DateTime? @map("contract_date") @db.Date
  investmentPeriodStart DateTime? @map("investment_period_start") @db.Date
  investmentPeriodEnd   DateTime? @map("investment_period_end") @db.Date
  fundTermYears         Int?      @map("fund_term_years")
  managementFeePct      Decimal?  @default(0) @db.Decimal(8, 4) @map("management_fee_pct")
  carryPct              Decimal?  @default(0) @db.Decimal(8, 4) @map("carry_pct")
  hurdleRatePct         Decimal?  @default(0) @db.Decimal(8, 4) @map("hurdle_rate_pct")
  wireBank              String?   @map("wire_bank")
  wireAccountName       String?   @map("wire_account_name")
  wireAccountNumber     String?   @map("wire_account_number")
  wireAba               String?   @map("wire_aba")
  wireSwift             String?   @map("wire_swift")
  wireReference         String?   @map("wire_reference")
  notes                 String?
  isActive              Boolean   @default(true) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  capitalCalls      CapitalCall[]
  distributions     Distribution[]
  navRecords        NavRecord[]
  investmentTargets InvestmentTarget[]
  notices           Notice[]
  fundReports       FundReport[]
  sigfSnapshot      SigfSnapshot?

  @@map("funds")
}

model CapitalCall {
  id                  String     @id @default(uuid())
  fundId              String     @map("fund_id")
  noticeDate          DateTime   @map("notice_date") @db.Date
  dueDate             DateTime   @map("due_date") @db.Date
  executionDate       DateTime?  @map("execution_date") @db.Date
  callNumber          Int?       @map("call_number")
  callPct             Decimal?   @default(0) @db.Decimal(8, 6) @map("call_pct")
  grossCallUsd        Decimal    @default(0) @db.Decimal(20, 6) @map("gross_call_usd")
  distributionUsd     Decimal    @default(0) @db.Decimal(20, 6) @map("distribution_usd")
  reinvestableUsd     Decimal    @default(0) @db.Decimal(20, 6) @map("reinvestable_usd")
  netCallUsd          Decimal    @default(0) @db.Decimal(20, 6) @map("net_call_usd")
  fxRate              Decimal?   @db.Decimal(12, 6) @map("fx_rate")
  netCallJpy          Decimal    @default(0) @db.Decimal(20, 2) @map("net_call_jpy")
  investmentAmountUsd Decimal?   @default(0) @db.Decimal(20, 6) @map("investment_amount_usd")
  managementFeeUsd    Decimal?   @default(0) @db.Decimal(20, 6) @map("management_fee_usd")
  expenseUsd          Decimal?   @default(0) @db.Decimal(20, 6) @map("expense_usd")
  status              CallStatus @default(pending)
  wireReference       String?    @map("wire_reference")
  wireFeeJpy          Decimal?   @default(0) @db.Decimal(12, 2) @map("wire_fee_jpy")
  isRecallable        Boolean    @default(false) @map("is_recallable")
  notes               String?
  approvedBy          String?    @map("approved_by")
  approvedAt          DateTime?  @map("approved_at")
  paidAt              DateTime?  @map("paid_at")
  sourcePdfId         String?    @map("source_pdf_id")  // FK to FundReport
  createdAt           DateTime   @default(now()) @map("created_at")

  fund Fund @relation(fields: [fundId], references: [id])

  @@map("capital_calls")
}

model Distribution {
  id               String    @id @default(uuid())
  fundId           String    @map("fund_id")
  distributionDate DateTime  @map("distribution_date") @db.Date
  distType         String    @map("dist_type")
  amountUsd        Decimal   @default(0) @db.Decimal(20, 6) @map("amount_usd")
  amountJpy        Decimal   @default(0) @db.Decimal(20, 2) @map("amount_jpy")
  fxRate           Decimal?  @db.Decimal(12, 6) @map("fx_rate")
  reinvestableUsd  Decimal   @default(0) @db.Decimal(20, 6) @map("reinvestable_usd")
  isRecallable     Boolean   @default(false) @map("is_recallable")
  recallExpiry     DateTime? @map("recall_expiry") @db.Date
  isRecalled       Boolean   @default(false) @map("is_recalled")
  createdAt        DateTime  @default(now()) @map("created_at")

  fund Fund @relation(fields: [fundId], references: [id])

  @@map("distributions")
}

model FxRate {
  id       String   @id @default(uuid())
  rateDate DateTime @map("rate_date") @db.Date
  usdJpy   Decimal  @db.Decimal(12, 6) @map("usd_jpy")
  source   String   @default("manual")

  @@map("fx_rates")
}

model NavRecord {
  id             String   @id @default(uuid())
  fundId         String   @map("fund_id")
  navDate        DateTime @map("nav_date") @db.Date
  navUsd         Decimal? @db.Decimal(20, 6) @map("nav_usd")
  period         String?
  sourceNoticeId String?  @map("source_notice_id")
  createdAt      DateTime @default(now()) @map("created_at")

  fund Fund @relation(fields: [fundId], references: [id])

  @@map("nav_records")
}

model InvestmentTarget {
  id             String    @id @default(uuid())
  fundId         String    @map("fund_id")
  projectName    String?   @map("project_name")
  actualName     String?   @map("actual_name")
  investmentDate DateTime? @map("investment_date") @db.Date
  amountUsd      Decimal?  @db.Decimal(20, 6) @map("amount_usd")
  investmentType String?   @map("investment_type")
  sector         String?
  geography      String?
  dealType       String?   @map("deal_type")
  createdAt      DateTime  @default(now()) @map("created_at")

  fund Fund @relation(fields: [fundId], references: [id])

  @@map("investment_targets")
}

model Notice {
  id           String    @id @default(uuid())
  filename     String
  originalName String?   @map("original_name")
  noticeType   String    @map("notice_type")
  status       String    @default("pending")
  fundId       String?   @map("fund_id")
  extractedData Json?    @map("extracted_data")
  confidence   Float?
  adminNotes   String?   @map("admin_notes")
  uploadedBy   String?   @map("uploaded_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  approvedAt   DateTime? @map("approved_at")

  fund Fund? @relation(fields: [fundId], references: [id])

  @@map("notices")
}

// ── FundReport — one record per parsed PDF ────────────────────────────────────
// Stores the raw extracted fields from sigulerGuffParser + source file reference.
// Each capital call created from a PDF gets a sourcePdfId pointing here.
model FundReport {
  id            String   @id @default(uuid())
  fundId        String   @map("fund_id")
  filename      String                          // original filename
  filePath      String   @map("file_path")      // relative path under uploads/
  reportType    String   @default("capital_call") @map("report_type")
  noticeDate    DateTime @map("notice_date") @db.Date
  dueDate       DateTime @map("due_date")       @db.Date
  batchId       String?  @map("batch_id")
  isInitialCall Boolean  @default(false) @map("is_initial_call")
  // Extracted values (keyword-anchored by sigulerGuffParser.ts)
  callPct       Decimal  @default(0) @db.Decimal(8, 6) @map("call_pct")
  netCallUsd    Decimal  @default(0) @db.Decimal(20, 6) @map("net_call_usd")
  cumulativePct Decimal  @default(0) @db.Decimal(8, 6) @map("cumulative_pct")
  commitmentUsd Decimal  @default(0) @db.Decimal(20, 6) @map("commitment_usd")
  // Full raw extraction as JSON (all parser fields for audit/reference)
  extractedData Json?    @map("extracted_data")
  // Link to the capital call created from this PDF (nullable — set after call is created)
  capitalCallId String?  @unique @map("capital_call_id")
  processedBy   String?  @map("processed_by")
  processedAt   DateTime @default(now()) @map("processed_at")

  fund Fund @relation(fields: [fundId], references: [id])

  @@map("fund_reports")
}

// ── SigfSnapshot — latest sigf.ts computed columns per fund ──────────────────
// Recalculated every time a new PDF is uploaded for the fund.
// Dashboard reads from here (DB) instead of re-parsing PDFs at request time.
model SigfSnapshot {
  id                 String   @id @default(uuid())
  fundId             String   @unique @map("fund_id")   // one snapshot per fund
  fundCode           String   @map("fund_code")         // e.g. 'SIGF'
  pdfCount           Int      @map("pdf_count")
  commitmentUsd      Decimal  @default(0) @db.Decimal(20, 6) @map("commitment_usd")
  // sigf.ts column totals (final row values)
  cumulativeDrawn    Decimal  @default(0) @db.Decimal(20, 6) @map("cumulative_drawn")    // E
  investmentCapacity Decimal  @default(0) @db.Decimal(20, 6) @map("investment_capacity") // F
  netCashFlow        Decimal  @default(0) @db.Decimal(20, 6) @map("net_cash_flow")       // G
  nonRecallableDist  Decimal  @default(0) @db.Decimal(20, 6) @map("non_recallable_dist") // L
  distributionsTotal Decimal  @default(0) @db.Decimal(20, 6) @map("distributions_total")
  dpi                Decimal  @default(0) @db.Decimal(12, 6)
  // Per-call rows as JSON array [{call_number, due_date, paid, cumulative_drawn, ...}]
  callRows           Json     @map("call_rows")
  computedAt         DateTime @default(now()) @map("computed_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  fund Fund @relation(fields: [fundId], references: [id])

  @@map("sigf_snapshots")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  tableName String   @map("table_name")
  recordId  String?  @map("record_id")
  userEmail String?  @map("user_email")
  userId    String?  @map("user_id")
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model OtpToken {
  id        String   @id @default(uuid())
  email     String
  token     String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("otp_tokens")
}

model CalculationRule {
  id                 String   @id @default(uuid())
  name               String
  description        String?
  formula            String
  explanation        String?
  outputUnit         String?  @map("output_unit")
  applicableTypes    String[] @default([]) @map("applicable_types")
  displayOnDashboard Boolean  @default(true) @map("display_on_dashboard")
  isActive           Boolean  @default(true) @map("is_active")
  sortOrder          Int      @default(0) @map("sort_order")
  createdBy          String?  @map("created_by")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  results CalculationResult[]

  @@map("calculation_rules")
}

model AttributeExtractor {
  id             String   @id @default(uuid())
  attributeName  String   @map("attribute_name")   // variable name used in formulas
  label          String                             // human-readable label
  keywords       String[] @default([])              // PDF keyword anchors to search for
  extractionType String   @default("usd") @map("extraction_type") // usd | pct | number | date | text
  isActive       Boolean  @default(true) @map("is_active")
  createdBy      String?  @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("attribute_extractors")
}

model CalculationResult {
  id          String   @id @default(uuid())
  ruleId      String   @map("rule_id")
  noticeId    String   @map("notice_id")
  fundId      String?  @map("fund_id")
  inputValues Json?    @map("input_values")
  outputValue Decimal? @db.Decimal(30, 6) @map("output_value")
  outputText  String?  @map("output_text")
  error       String?
  createdAt   DateTime @default(now()) @map("created_at")

  rule CalculationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@map("calculation_results")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  userEmail String?  @map("user_email")
  type      String   // 'user_registered' | 'user_approved' | 'user_rejected' | 'notice_uploaded' | 'notice_approved' | 'notice_rejected' | 'capital_call_due' | 'general'
  title     String
  message   String
  link      String?  // frontend route to navigate to
  isRead    Boolean  @default(false) @map("is_read")
  metadata  Json?    // extra data
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}
